# Porta da API
PORT=3001
# Segredo do JWT — OBRIGATÓRIO trocar em produção (use: openssl rand -hex 32)
JWT_SECRET=troque-este-segredo-em-producao
# Validade do token
JWT_EXPIRES=8h
# Origem permitida no CORS (URL do frontend)
CORS_ORIGIN=http://localhost:5173
# Banco: vazio = SQLite local (dev). Na VPS use Postgres:
# DATABASE_URL=postgres://usuario:senha@localhost:5432/vetcare
DATABASE_URL=
# Opcional: chave da Anthropic para diagnóstico com IA generativa.
# Sem chave, o motor de regras clínicas local é usado.
ANTHROPIC_API_KEY=
